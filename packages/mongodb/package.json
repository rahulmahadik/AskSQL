  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@asksql/core": "workspace:^"
  },
  "peerDependencies": {
    "mongodb": ">=6.0"
  },
  "devDependencies": {
    "mongodb": "^6.10.0"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahulmahadik/AskSQL.git",
    "directory": "packages/mongodb"
  },
  "homepage": "https://github.com/rahulmahadik/AskSQL#readme",
  "bugs": "https://github.com/rahulmahadik/AskSQL/issues",
  "publishConfig": {
    "access": "public"
  },
  "author": "Rahul Mahadik <rahultkiet@gmail.com>",
  "keywords": [
    "mongodb",
