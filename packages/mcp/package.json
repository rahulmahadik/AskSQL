{
  "name": "@asksql/mcp",
  "version": "0.1.6",
  "description": "Model Context Protocol server for AskSQL: exposes list-connections / schema / query / run as MCP tools so AI agents can safely query registered databases (read-only, guarded).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@asksql/core": "workspace:^"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahulmahadik/AskSQL.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/rahulmahadik/AskSQL#readme",
  "bugs": "https://github.com/rahulmahadik/AskSQL/issues",
  "publishConfig": {
    "access": "public"
  },
  "author": "Rahul Mahadik <rahultkiet@gmail.com>",
  "keywords": [
    "sql",
    "text-to-sql",
    "nl2sql",
    "natural-language",
    "database",
    "ai",
    "llm",
    "sql-generation",
    "database-chat",
    "ask-database",
    "mcp",
    "model-context-protocol",
    "agents",
    "tools",
    "mcp-server"
  ]
}
