{
  "name": "@asksql/widget",
  "version": "0.2.0",
  "description": "Vanilla-JS AskSQL embed for non-React pages. Mounts the bubble/chat into a shadow root so host CSS never bleeds in or out.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/asksql-widget.js",
  "jsdelivr": "./dist/asksql-widget.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc -b && node esbuild.mjs"
  },
  "dependencies": {
    "@asksql/react": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahulmahadik/AskSQL.git",
    "directory": "packages/widget"
  },
  "homepage": "https://github.com/rahulmahadik/AskSQL#readme",
  "bugs": "https://github.com/rahulmahadik/AskSQL/issues",
  "publishConfig": {
    "access": "public"
  },
  "author": "Rahul Mahadik <rahultkiet@gmail.com>",
  "keywords": [
    "sql",
    "text-to-sql",
    "nl2sql",
    "natural-language",
    "database",
    "ai",
    "llm",
    "sql-generation",
    "database-chat",
    "ask-database",
    "embed",
    "widget",
    "vanilla-js",
    "shadow-dom",
    "text2sql"
  ]
}
